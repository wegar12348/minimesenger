# misegesait / R&DMESEGE — Apache конфигурация
# Для Sprinthost и других Apache-хостингов

Options -Indexes
ServerSignature Off

# Кодировка
AddDefaultCharset UTF-8

# GZIP сжатие (ускорение загрузки)
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json
</IfModule>

# Кэширование статики
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css "access plus 7 days"
  ExpiresByType application/javascript "access plus 7 days"
  ExpiresByType image/png "access plus 30 days"
  ExpiresByType image/jpg "access plus 30 days"
</IfModule>

# PHP API: красивые URL (опционально)
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Редирект api запросов
  RewriteRule ^api/(.*)$ php/api.php?action=$1 [QSA,L]

  # Защита папки data
  RewriteRule ^php/data/ - [F,L]
</IfModule>

# Запрет доступа к служебным файлам
<FilesMatch "\.(json|md|log|sh|bat)$">
  Order allow,deny
  Deny from all
</FilesMatch>

# Разрешить только index.html как стартовый файл
DirectoryIndex index.html
